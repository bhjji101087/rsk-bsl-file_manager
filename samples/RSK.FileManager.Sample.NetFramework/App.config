<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="FileManager:Provider" value="FileSystem" />
    <add key="FileManager:GenerateUrlOnUpload" value="false" />
    <add key="FileManager:FileSystem:RootPath" value="C:\Temp\RSKUploads" />
    <add key="FileManager:FileSystem:ServeBaseUrl" value="https://localhost/files" />
    <add key="FileManager:FileSystem:TokenSecret" value="dev-secret-change-me-min-32-characters!!" />
  </appSettings>
</configuration>
