{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "FileManager": {
    "Provider": "FileSystem",
    "MaxFileSizeBytes": 104857600,
    "DefaultSecureUrlExpiryHours": 1,
    "GenerateUrlOnUpload": true,
    "EnableContentSniffing": true,
    "AllowedExtensions": [],

    "FileSystem": {
      "RootPath": "uploads",
      "ServeBaseUrl": "https://localhost:5001/files",
      "TokenSecret": "dev-secret-change-me-min-32-characters!!"
    },

    "//AzureBlob (set Provider to AzureBlob to use)": "",
    "AzureBlob": {
      "UseManagedIdentity": false,
      "AccountName": "",
      "ConnectionString": "UseDevelopmentStorage=true"
    }
  }
}
